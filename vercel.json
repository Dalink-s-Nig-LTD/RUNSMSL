{
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": { "runtime": "nodejs18.x" }
  },
  "routes": [
    { "src": "^/api/(.*)", "dest": "/api/index.js" },
    { "src": "^/(.*)", "dest": "/api/index.js" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
